# ------------------------------------------------------------
# Terraform state (never commit)
# ------------------------------------------------------------
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# ------------------------------------------------------------
# Terraform working directories
# ------------------------------------------------------------
.terraform/
.terraform.lock.hcl

# ------------------------------------------------------------
# Terraform plan binaries (safe to ignore)
# ------------------------------------------------------------
*.tfplan
*.binary

# ------------------------------------------------------------
# Evidence bundles (root-level only)
# DO NOT ignore week1/evidence/ because Week 3 requires plan.json
# ------------------------------------------------------------
/evidence/
evidence-*.tar.gz
*.tar.gz

# Allow Week 1 evidence to be committed
!week1/evidence/
!week1/evidence/plan.json

# Week 5 evidence contains sensitive data 
# Security Hub findings exports
security-hub-findings.json
security-hub-findings.json.sig

# Any variations or backups
security-hub-findings*.json
security-hub-findings*.sig

# ------------------------------------------------------------
# Keys and sensitive cryptographic material
# ------------------------------------------------------------
*.pem
*.key
*.crt

# ------------------------------------------------------------
# Conftest artifacts (local only)
# ------------------------------------------------------------
conftest-results.txt

# ------------------------------------------------------------
# Local environment files
# ------------------------------------------------------------
*.env
*.local

# ------------------------------------------------------------
# OS junk
# ------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Windows shortcuts
# ------------------------------------------------------------
*.lnk
